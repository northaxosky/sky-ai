# Copy this file to .env and fill in your values.
# .env is gitignored; this template (.env.example) is committed.

# HuggingFace Hub token. Used by:
#   - skyai train/eval (HellaSwag + LAMBADA eval data; faster, rate-limit-free HF downloads)
#   - scripts/shard_text.py (downloading/tokenizing HF text datasets)
#   - scripts/hellaswag.py (loading pretrained GPT-2 from HF)
#   - scripts/train_reference.py (HF weight loading via from_pretrained)
# Get yours at: https://huggingface.co/settings/tokens (Read scope is enough)
HF_TOKEN=hf_...

# HuggingFace cache root (optional). Overrides the default ~/.cache/huggingface.
# Leave this COMMENTED to cache outside the repo (recommended). A placeholder or
# blank value makes HF create a junk dir in the repo, so only set it to a real,
# gitignored path.
# HF_HOME=

# Weights & Biases API key. Used by skyai train (run tracking when log.wandb=true)
# and scripts/train_reference.py. Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=...
